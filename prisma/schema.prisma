generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  bookmarks     Bookmark[]
  collections   Collection[]
  tags          Tag[]
  learningPaths LearningPath[]
  chatSessions  ChatSession[]
  apiKeys       ApiKey[]
  annotations   Annotation[]
  createdAt     DateTime      @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Bookmark {
  id          String              @id @default(cuid())
  url         String
  title       String
  description String?
  coverImage  String?
  favicon     String?
  siteName    String?
  contentType String              @default("webpage")
  metadata    String?
  aiSummary   String?
  shareToken  String?             @unique
  embedding   String?
  status      String              @default("unread")
  categoryId  String?
  category    Category?           @relation(fields: [categoryId], references: [id])
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags        BookmarkTag[]
  collections CollectionBookmark[]
  pathItems     LearningPathItem[]
  trackers      HotnessTracker[]
  annotations   Annotation[]
  archiveHtml   String?
  archiveText   String?
  archivedAt    DateTime?
  archiveStatus String?
  linkStatus        String?   // healthy | redirect | broken | unknown
  linkStatusCode    Int?      // latest HTTP status code
  linkCheckedAt     DateTime? // last check timestamp
  linkCheckError    String?   // latest error message
  linkRedirectUrl   String?   // redirect target URL
  linkTitleChanged  Boolean?  // title changed since last check
  createdAt     DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  readAt      DateTime?
  order       Int                 @default(0)
}

model Tag {
  id        String        @id @default(cuid())
  name      String
  slug      String
  color     String?
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmarks BookmarkTag[]

  @@unique([userId, slug])
}

model BookmarkTag {
  bookmarkId String
  tagId      String
  bookmark   Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bookmarkId, tagId])
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  order     Int        @default(0)
  bookmarks Bookmark[]
}

model Collection {
  id        String                @id @default(cuid())
  name      String
  slug      String
  isPublic  Boolean               @default(false)
  isSmart   Boolean               @default(false)
  rules     String?               // JSON: SmartCollectionRules
  sortBy    String?               // createdAt | updatedAt | title
  sortOrder String?               // asc | desc
  maxItems  Int?                  // null = unlimited
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmarks CollectionBookmark[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@unique([userId, slug])
}

model CollectionBookmark {
  collectionId String
  bookmarkId   String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  bookmark     Bookmark   @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  addedAt      DateTime   @default(now())

  @@id([collectionId, bookmarkId])
}

model HotnessTracker {
  id            String   @id @default(cuid())
  bookmarkId    String   @unique
  sourceType    String   @default("github")
  enabled       Boolean  @default(true)
  lastCheckedAt DateTime?
  createdAt     DateTime @default(now())

  bookmark  Bookmark          @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  snapshots HotnessSnapshot[]
}

model HotnessSnapshot {
  id          String   @id @default(cuid())
  trackerId   String
  timestamp   DateTime @default(now())
  stars       Int?
  forks       Int?
  openIssues  Int?
  views       Int?
  likes       Int?
  httpStatus  Int?
  snapshot    String?

  tracker HotnessTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@index([trackerId, timestamp])
}

model ApiKey {
  id        String    @id @default(cuid())
  name      String
  key       String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedAt DateTime?
  createdAt DateTime  @default(now())
}

model LearningPath {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  targetTags  String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items LearningPathItem[]
}

model LearningPathItem {
  id               String   @id @default(cuid())
  pathId           String
  bookmarkId       String
  order            Int
  stage            String?
  difficulty       String?
  estimatedMinutes Int?
  isOptional       Boolean  @default(false)
  isCompleted      Boolean  @default(false)
  completedAt      DateTime?

  path     LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  bookmark Bookmark     @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  notes    PathNote[]
}

model PathNote {
  id        String   @id @default(cuid())
  itemId    String
  content   String
  type      String   @default("takeaway")
  createdAt DateTime @default(now())

  item LearningPathItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model Annotation {
  id         String   @id @default(cuid())
  userId     String
  bookmarkId String
  type       String   // highlight | note
  color      String?  // yellow | green | blue | red
  text       String   // the selected original text
  note       String?  // margin note content
  anchor     String   // JSON: { xpath, startOffset, endOffset, textPrefix, textSuffix, selectedText }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmark Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)

  @@index([userId, bookmarkId])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        // Auto-generated from first question
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  role        String      // user | assistant
  content     String      // Markdown
  citations   String?     // JSON: [{ bookmarkId, title, snippet, relevanceScore }]
  feedback    String?     // positive | negative | null
  createdAt   DateTime    @default(now())
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
